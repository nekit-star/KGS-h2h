PAYMENTSGATE_BASE_URL=https://secure.easysendglobal.com
PAYMENTSGATE_ADDR=:8080
PAYMENTSGATE_HTTP_TIMEOUT_SECONDS=15
PAYMENTSGATE_CREDENTIALS_POLL_INTERVAL_MS=1500
PAYMENTSGATE_CREDENTIALS_WAIT_SECONDS=20
PAYMENTSGATE_ALLOWED_CLOCK_SKEW_SECONDS=0
