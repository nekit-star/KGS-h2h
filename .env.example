PAYMENTSGATE_FAIL_WEBHOOK_URL=https://webhook.site/b71e1b94-2e0b-43b1-8544-b9fe3325db9b

# Method -> terminal mapping.
KGS_METHOD_ELQR_PRIMARY_TERMINAL=primary
KGS_METHOD_ELQR_FTD_TERMINAL=primary
KGS_METHOD_ELQR_TRUSTED_TERMINAL=primary
KGS_METHOD_KGSPHONE_PRIMARY_TERMINAL=primary
