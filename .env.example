KGS_METHOD_ODENGI_TRUSTED_TERMINAL=odengi_trusted

# Put PEM values in one line with \n escapes.
# Example:
# KGS_PRIMARY_BEGIN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY\n-----END PUBLIC KEY-----"
# KGS_PRIMARY_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----"

